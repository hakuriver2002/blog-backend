    "/api/auth/reset-password": {
      "post": {
        "summary": "Đặt lại mật khẩu",
        "tags": [
          "Auth"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "password"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string",
                    "example": "NewPass@456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Đặt lại thành công"
          },
          "400": {
            "description": "Token không hợp lệ hoặc hết hạn"
          }
        }
      }
    },
