      "post": {
        "summary": "Quên mật khẩu — gửi email reset",
        "tags": [
          "Auth"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "admin@karatedo.vn"
                  }
                }
              }
            }
          }
