            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "note"
                ],
                "properties": {
                  "note": {
                    "type": "string",
                    "example": "Nội dung chưa đủ chi tiết"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Từ chối thành công"
          }
        }
      }
