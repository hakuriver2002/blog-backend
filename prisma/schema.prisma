generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  admin
  editor
  trainer
  member
}

enum UserStatus {
  pending
  active
  inactive
  rejected
}

enum ArticleCategory {
  club_news
  events
  regional_news
  internal
}

enum ArticleStatus {
  draft
  pending
  published
  rejected
  archived
}

enum ReviewAction {
  submitted
  approved
  rejected
  revised
  archived
}

enum CommentStatus {
  visible
  hidden
  deleted
}

// ─────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────

model User {
  id            String      @id @default(uuid())
  fullName      String      @map("full_name") @db.VarChar(100)
  email         String      @unique @db.VarChar(150)
  passwordHash  String?     @map("password_hash") @db.VarChar(255)
  avatarUrl     String?     @map("avatar_url") @db.VarChar(500)
  role          UserRole    @default(member)
  status        UserStatus  @default(pending)
  googleId      String?     @unique @map("google_id") @db.VarChar(150)
  refreshTokens RefreshToken[]

  // Relations
  approvedById  String?     @map("approved_by")
  approvedBy    User?       @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedUsers User[]      @relation("ApprovedBy")
  approvedAt    DateTime?   @map("approved_at")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Back-relations
  articles        Article[]
  comments        Comment[]       @relation("CommentAuthor")
  hiddenComments  Comment[]       @relation("CommentHiddenBy")
  articleReviews  ArticleReview[]
  resetTokens     PasswordResetToken[]
  notifications         Notification[]  @relation("UserNotifications")
  triggeredNotifications Notification[] @relation("NotificationActor")
  athleteProfile AthleteProfile? @relation("AthleteProfile")
  likes     ArticleLike[]     @relation("ArticleLikes")
  bookmarks ArticleBookmark[] @relation("ArticleBookmarks")
  createdEvents       Event[]             @relation("EventCreator")
  eventRegistrations  EventRegistration[] @relation("EventRegistrations")
  createdTags  Tag[] @relation("TagCreator")

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  used      Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model Article {
  id           String          @id @default(uuid())
  title        String          @db.VarChar(300)
  slug         String          @unique @db.VarChar(350)
  excerpt      String?         @db.Text
  content      String          @db.Text
  thumbnailUrl String?         @map("thumbnail_url") @db.VarChar(500)
  category     ArticleCategory
  status       ArticleStatus   @default(draft)
  isFeatured   Boolean         @default(false) @map("is_featured")
  viewCount    Int             @default(0) @map("view_count")
  publishedAt  DateTime?       @map("published_at")

  authorId     String          @map("author_id")
  author       User            @relation(fields: [authorId], references: [id])

  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  // Back-relations
  images       ArticleImage[]
  tags         ArticleTag[]
  comments     Comment[]
  reviews      ArticleReview[]
  likes     ArticleLike[]
  bookmarks ArticleBookmark[]

  @@index([status])
  @@index([category])
  @@index([authorId])
  @@index([publishedAt])
  @@index([title])
  @@map("articles")
}

model ArticleImage {
  id         String   @id @default(uuid())
  articleId  String   @map("article_id")
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  imageUrl   String   @map("image_url") @db.VarChar(500)
  caption    String?  @db.VarChar(300)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("article_images")
}

model Tag {
  id          String       @id @default(uuid())
  name        String       @unique @db.VarChar(100)
  slug        String       @unique @db.VarChar(120)
 
  description String?      @db.Text
  color       String?      @db.VarChar(7)    
  icon        String?      @db.VarChar(50)   
  isActive    Boolean      @default(true) @map("is_active")
  usageCount  Int          @default(0) @map("usage_count")  
 
  createdById String?      @map("created_by")
  createdBy   User?        @relation("TagCreator", fields: [createdById], references: [id], onDelete: SetNull)
 
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
 
  articles    ArticleTag[]
 
  @@index([slug])
  @@index([isActive])
  @@index([usageCount])
  @@map("tags")
}

model ArticleTag {
  articleId String  @map("article_id")
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String  @map("tag_id")
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model ArticleReview {
  id          String       @id @default(uuid())
  articleId   String       @map("article_id")
  article     Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  reviewerId  String?      @map("reviewer_id")
  reviewer    User?        @relation(fields: [reviewerId], references: [id])
  action      ReviewAction
  note        String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("article_reviews")
}

model Comment {
  id        String        @id @default(uuid())
  articleId String        @map("article_id")
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String        @map("user_id")
  user      User          @relation("CommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?       @map("parent_id")
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[]     @relation("CommentReplies")
  content   String        @db.Text
  status    CommentStatus @default(visible)

  hiddenById  String?   @map("hidden_by")
  hiddenBy    User?     @relation("CommentHiddenBy", fields: [hiddenById], references: [id])
  hiddenAt    DateTime? @map("hidden_at")
  hiddenReason String?  @map("hidden_reason") @db.VarChar(300)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("comments")
}

enum NotificationType {
  article_approved    // Bài viết được duyệt
  article_rejected    // Bài viết bị từ chối
  article_commented   // Có comment mới trên bài của mình
  comment_replied     // Có người reply comment của mình
  user_approved       // Tài khoản được phê duyệt
  user_pending        // Có user mới chờ duyệt (gửi cho admin)
}
 
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")         // Người nhận
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
 
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String           @db.VarChar(500)
  isRead    Boolean          @default(false) @map("is_read")
 
  // Metadata — link đến resource liên quan
  articleId String?          @map("article_id")
  commentId String?          @map("comment_id")
  actorId   String?          @map("actor_id")        // Người thực hiện hành động
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
 
  createdAt DateTime         @default(now()) @map("created_at")
 
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}
 
enum BeltColor {
  white       // Trắng
  yellow      // Vàng
  orange      // Cam
  green       // Xanh lá
  blue        // Xanh dương
  purple      // Tím
  red         // Đỏ
  brown       // Nâu
  black_1dan  // Đen 1 đẳng
  black_2dan  // Đen 2 đẳng
  black_3dan  // Đen 3 đẳng
  black_4dan  // Đen 4 đẳng
  black_5dan  // Đen 5 đẳng
}
 
enum AchievementLevel {
  club        // Cấp CLB
  district    // Cấp Quận/Huyện
  provincial  // Cấp Tỉnh/Thành
  national    // Cấp Quốc gia
  regional    // Cấp Khu vực (Đông Nam Á, châu Á...)
  world       // Cấp Thế giới
}
 
enum AchievementMedal {
  gold    // Huy chương Vàng
  silver  // Huy chương Bạc
  bronze  // Huy chương Đồng
  top4    // Hạng 4
  other   // Khác (giải khuyến khích, chứng nhận...)
}
 
enum AthleteDiscipline {
  kata          // Quyền
  kumite        // Đối kháng
  kata_team     // Quyền đồng đội
  kumite_team   // Đối kháng đồng đội
  both          // Cả hai
}
 
 
model AthleteProfile {
  id              String            @id @default(uuid())
  userId          String            @unique @map("user_id")
  user            User              @relation("AthleteProfile", fields: [userId], references: [id], onDelete: Cascade)
 
  // Thông tin cơ bản
  dateOfBirth     DateTime?         @map("date_of_birth")
  gender          String?           @db.VarChar(10)        // male / female / other
  height          Int?              // cm
  weight          Float?            // kg
  nationality     String?           @default("Việt Nam") @db.VarChar(100)
  hometown        String?           @map("home_town") @db.VarChar(200)
  club            String?           @db.VarChar(200)       // Tên CLB / võ đường
 
  // Thông tin tập luyện
  discipline      AthleteDiscipline @default(both)
  startYear       Int?              @map("start_year")     // Năm bắt đầu tập
  currentBelt     BeltColor         @default(white) @map("current_belt")
  coachName       String?           @map("coach_name") @db.VarChar(100)
 
  // Bio & Social
  bio             String?           @db.Text
  isPublic        Boolean           @default(true) @map("is_public")  // Hiển thị công khai
 
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
 
  // Relations
  achievements    Achievement[]
  beltHistory     Belt[]
 
  @@map("athlete_profiles")
}
 
model Achievement {
  id              String            @id @default(uuid())
  athleteId       String            @map("athlete_id")
  athlete         AthleteProfile    @relation(fields: [athleteId], references: [id], onDelete: Cascade)
 
  // Thông tin giải đấu
  tournamentName  String            @map("tournament_name") @db.VarChar(300)
  discipline      AthleteDiscipline
  level           AchievementLevel
  medal           AchievementMedal
  year            Int
  location        String?           @db.VarChar(200)       // Địa điểm tổ chức
  weightCategory  String?           @map("weight_category") @db.VarChar(50) // Hạng cân (kumite)
  kataName        String?           @map("kata_name") @db.VarChar(100)      // Tên bài quyền (kata)
  description     String?           @db.Text
 
  // Minh chứng
  images          AchievementImage[]
 
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
 
  @@index([athleteId])
  @@index([year])
  @@index([level])
  @@map("achievements")
}
 
model AchievementImage {
  id            String      @id @default(uuid())
  achievementId String      @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  imageUrl      String      @map("image_url") @db.VarChar(500)
  caption       String?     @db.VarChar(300)
  sortOrder     Int         @default(0) @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at")
 
  @@map("achievement_images")
}
 
model Belt {
  id          String         @id @default(uuid())
  athleteId   String         @map("athlete_id")
  athlete     AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  belt        BeltColor
  achievedAt  DateTime       @map("achieved_at")           // Ngày thăng đai
  examiner    String?        @db.VarChar(100)              // Người kiểm tra
  location    String?        @db.VarChar(200)
  note        String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at")
 
  @@index([athleteId])
  @@map("belts")
}

model ArticleLike {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("ArticleLikes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
 
  @@unique([articleId, userId])  // mỗi user chỉ like 1 lần
  @@index([articleId])
  @@index([userId])
  @@map("article_likes")
}
 
model ArticleBookmark {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("ArticleBookmarks", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
 
  @@unique([articleId, userId])  // mỗi user chỉ bookmark 1 lần
  @@index([userId])
  @@map("article_bookmarks")
}

enum EventStatus {
  draft       // Nháp
  published   // Đã công bố
  cancelled   // Đã hủy
  completed   // Đã kết thúc
}
 
enum EventCategory {
  tournament    // Giải đấu
  training      // Tập huấn
  seminar       // Hội thảo / Seminar
  grading       // Thi lên đai
  friendly      // Giao hữu
  other         // Khác
}
 
enum EventLevel {
  club          // Cấp CLB
  district      // Cấp Quận/Huyện
  provincial    // Cấp Tỉnh/Thành
  national      // Cấp Quốc gia
  international // Quốc tế
}
 
model Event {
  id              String        @id @default(uuid())
 
  // Thông tin cơ bản
  title           String        @db.VarChar(300)
  slug            String        @unique @db.VarChar(350)
  description     String?       @db.Text
  thumbnailUrl    String?       @map("thumbnail_url") @db.VarChar(500)
 
  // Phân loại
  category        EventCategory
  level           EventLevel    @default(club)
  status          EventStatus   @default(draft)
 
  // Thời gian
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  registrationDeadline DateTime? @map("registration_deadline")
 
  // Địa điểm
  location        String        @db.VarChar(300)       // Tên địa điểm
  address         String?       @db.VarChar(500)       // Địa chỉ đầy đủ
  city            String?       @db.VarChar(100)
 
  // Hạng mục thi đấu (lưu dạng JSON array)
  divisions       String?       @db.Text               // JSON: ["Kata Nam", "Kumite -60kg", ...]
 
  // Đăng ký
  registrationUrl String?       @map("registration_url") @db.VarChar(500)
  maxParticipants Int?          @map("max_participants")
  fee             Float?                               // Phí tham dự (VND)
  feeDescription  String?       @map("fee_description") @db.VarChar(300)
 
  // Thông tin tổ chức
  organizer       String?       @db.VarChar(200)       // Đơn vị tổ chức
  contactEmail    String?       @map("contact_email") @db.VarChar(150)
  contactPhone    String?       @map("contact_phone") @db.VarChar(20)
 
  // Nội bộ
  isPublic        Boolean       @default(true) @map("is_public")
  isFeatured      Boolean       @default(false) @map("is_featured")
  viewCount       Int           @default(0) @map("view_count")
 
  // Creator
  createdById     String        @map("created_by")
  createdBy       User          @relation("EventCreator", fields: [createdById], references: [id])
 
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
 
  // Relations
  registrations   EventRegistration[]
 
  @@index([status])
  @@index([category])
  @@index([startDate])
  @@index([createdById])
  @@map("events")
}
 
model EventRegistration {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation("EventRegistrations", fields: [userId], references: [id], onDelete: Cascade)
 
  // Thông tin đăng ký
  division    String?  @db.VarChar(100)   // Hạng mục đăng ký
  note        String?  @db.Text           // Ghi chú thêm
  status      String   @default("pending") @db.VarChar(20) // pending | confirmed | cancelled
 
  registeredAt DateTime @default(now()) @map("registered_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
 
  @@unique([eventId, userId])             // Mỗi user chỉ đăng ký 1 lần/event
  @@index([eventId])
  @@index([userId])
  @@map("event_registrations")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}